$C = "Common.ui";

$C.@PageOverlay {}

$C.@Container {
  Anchor: (Width: 720, Height: 700);

  #Title {
    Group {
      $C.@Title {
        @Text = "Waystones";
      }
    }
  }

  #Content {
    LayoutMode: Top;
    Padding: (Horizontal: 20);

    // Filter dropdowns row
    Group #FilterRow {
      LayoutMode: Left;
      Anchor: (Top: 16, Height: 50);

      // Visibility filter dropdown
      Group #VisibilityFilter {
        LayoutMode: Top;

        Label {
          Text: "Visibility";
          Style: (FontSize: 11, TextColor: #6a7a8a);
        }

        $C.@DropdownBox #VisibilityInput {
          @Anchor = (Top: 4, Height: 32, Width: 80);
        }
      }

      Group {
        Anchor: (Width: 16);
      }

      // Network filter dropdown (hidden when networks disabled)
      Group #NetworkFilter {
        LayoutMode: Top;
        Visible: false;

        Label {
          Text: "Network";
          Style: (FontSize: 11, TextColor: #6a7a8a);
        }

        $C.@DropdownBox #NetworkInput {
          @Anchor = (Top: 4, Height: 32, Width: 90);
        }
      }
    }

    // Waystone list container
    Group #ListContainer {
      LayoutMode: Top;
      Anchor: (Top: 8);

      Label #NoWaystones {
        Text: "No waystones match your filters.";
        Style: (FontSize: 14, TextColor: #6a7a8a, HorizontalAlignment: Center);
        Anchor: (Top: 16);
        Visible: false;
      }

      Group #WarpList {
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        Anchor: (Left: 0, Right: 0, Top: 8, Height: 530);
      }
    }
  }
}

$C.@BackButton {}
